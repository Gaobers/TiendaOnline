@using Microsoft.AspNetCore.Mvc.Rendering
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TiendaOnline.AppMVC</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TiendaOnline.AppMVC.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/Producto/Index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Producto/Details.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Producto/Delete.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/ProductoImagen/Index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ProductoImagen/Create.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ProductoImagen/Delete.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ProductoImagen/Details.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ProductoImagen/Edit.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">


    @RenderSection("Styles", required: false)
</head>

<body>
<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom navbar-shadow">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2"
               asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-bag-heart-fill text-primary"></i>
                <span>TiendaOnline</span>
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Menú">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">

                <!-- Menú Izquierda -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-lg-1">
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home" asp-action="Index"
                           asp-route-id=""
                           class-active="true">
                            <i class="bi bi-house-door me-1"></i> Inicio
                        </a>
                    </li>

                    <!-- Dropdown Catálogo -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <i class="bi bi-grid me-1"></i> Catálogo
                        </a>

                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Producto" asp-action="Index">
                                    <i class="bi bi-box-seam me-2"></i> Productos
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="ProductoImagen" asp-action="Index">
                                    <i class="bi bi-image me-2"></i> Imágenes de producto
                                </a>
                            </li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Pedidos" asp-action="Index">
                            <i class="bi bi-receipt me-1"></i> Pedidos
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Usuarios" asp-action="Index">
                            <i class="bi bi-people me-1"></i> Usuarios
                        </a>
                    </li>

@*                     <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home" asp-action="Privacy">
                            <i class="bi bi-shield-lock me-1"></i> Privacidad
                        </a>
                    </li> *@
                </ul>

            </div>
        </div>
    </nav>
</header>

<!-- Contenido -->
<div class="container-fluid py-3">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted bg-white">
    <div class="container-fluid py-3 d-flex justify-content-between align-items-center">
        <div>
            &copy; 2026 - TiendaOnline.AppMVC
        </div>
        <div>
            <a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">
                Privacidad
            </a>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>>

<script src="~/js/Producto/Edit.js" asp-append-version="true"></script>

<script src="~/js/ProductoImagen/Create.js" asp-append-version="true"></script>
<script src="~/js/ProductoImagen/Edit.js" asp-append-version="true"></script>

<script src="~/js/Producto/Edit.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>