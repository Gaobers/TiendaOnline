@using TiendaOnline.AppMVC.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model Pedido

@{
    ViewData["Title"] = "Crear Pedido";
}

<div class="container">
    <h2>Crear Nuevo Pedido</h2>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        
        <div class="row g-3">
            <div class="col-12">
                <label asp-for="NombreCliente" class="form-label fw-bold">Nombre del Cliente</label>
                <input asp-for="NombreCliente" class="form-control" />
                <span asp-validation-for="NombreCliente" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="DireccionEntrega" class="form-label fw-bold">Dirección de Entrega</label>
                <input asp-for="DireccionEntrega" class="form-control" placeholder="Calle, Número, Ciudad" />
                <span asp-validation-for="DireccionEntrega" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Total" class="form-label fw-bold">Total del Pedido (USD)</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Total" class="form-control" type="number" step="0.01" />
                </div>
                <span asp-validation-for="Total" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Estado" class="form-label fw-bold">Estado Inicial</label>
                <select asp-for="Estado" class="form-select">
                    <option value="Pendiente">Pendiente</option>
                    <option value="Pagado">Pagado</option>
                    <option value="Enviado">Enviado</option>
                </select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>

            <div class="col-12 mt-4">
                <button type="submit" class="btn btn-primary">Guardar Pedido</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </div>
    </form>
</div>