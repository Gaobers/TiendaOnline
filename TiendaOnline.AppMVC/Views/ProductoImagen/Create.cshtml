@model TiendaOnline.AppMVC.Models.ProductoImagen

@{
    ViewData["Title"] = "Nueva imagen";
}


<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">Nueva imagen de producto</h3>
        <div class="text-muted">Asigna una URL y define si será principal</div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        ← Volver
    </a>
</div>

<div class="row g-3">
    <!-- Formulario -->
    <div class="col-lg-7 col-xl-6">
        <div class="card shadow-sm cardx">
            <div class="card-body p-4">
                <form asp-action="Create" novalidate>
@*                     <div asp-validation-summary="All" class="alert alert-danger py-2" role="alert"></div>
 *@
                    <div class="row g-3">
                        <!-- Producto -->
                        <div class="col-12">
                            <label asp-for="ProductoId" class="form-label fw-semibold">Producto</label>
                            <select asp-for="ProductoId" class="form-select" asp-items="ViewBag.ProductoId">
                                <option value="">-- Selecciona un producto --</option>
                            </select>
                            <span asp-validation-for="ProductoId" class="text-danger small"></span>
                        </div>

                        <!-- URL -->
                        <div class="col-12">
                            <label asp-for="Url" class="form-label fw-semibold">URL de la imagen</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-link-45deg"></i></span>
                                <input asp-for="Url" class="form-control" id="urlInput"
                                       placeholder="https://..." autocomplete="off" />
                            </div>
                            <span asp-validation-for="Url" class="text-danger small"></span>
                        </div>

                        <!-- Principal -->
                        <div class="col-12">
                            <label class="form-label fw-semibold d-block">Principal</label>
                            <div class="form-check form-switch">
                                <input class="form-check-input" asp-for="EsPrincipal" id="principalSwitch" />
                                <label class="form-check-label" for="principalSwitch">
                                    Marcar como imagen principal
                                </label>
                            </div>
                        </div>

                        <!-- Botones -->
                        <div class="col-12 d-flex gap-2 pt-2">
                            <button type="submit" class="btn btn-primary">
                                Guardar
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Preview -->
    <div class="col-lg-5 col-xl-6">
        <div class="card shadow-sm cardx">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="fw-semibold">Vista previa</div>
                    <small class="text-muted">Se actualiza con la URL</small>
                </div>

                <div class="preview" id="previewBox">
                    <span>PREVIEW</span>
                </div>
            </div>
        </div>
    </div>
</div>
