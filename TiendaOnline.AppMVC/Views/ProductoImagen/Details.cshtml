@model TiendaOnline.AppMVC.Models.ProductoImagen

@{
    ViewData["Title"] = "Detalle de imagen";

    var esPrincipal = Model.EsPrincipal;
    var productoNombre = Model.Producto?.Nombre;
    var productoId = Model.ProductoId;
}


<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">Detalle de imagen</h3>
        <div class="text-muted">Información del registro</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
        <a asp-action="Edit" asp-route-id="@Model.ProductoImagenId" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i> Editar
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Datos -->
    <div class="col-lg-7 col-xl-6">
        <div class="card shadow-sm cardx">
            <div class="card-body p-4">
                <div class="row g-3">

                    <div class="col-12">
                        <div class="label">Producto</div>
                        <div class="value">
                            @(string.IsNullOrWhiteSpace(productoNombre) ? $"Producto #{productoId}" : productoNombre)
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="label">URL</div>
                        <div class="value mono truncate">@Model.Url</div>
                    </div>

                    <div class="col-md-6">
                        <div class="label">Tipo</div>
                        <div class="value">
                            @if (esPrincipal)
                            {
                                <span class="badge-soft badge-soft-primary">PRINCIPAL</span>
                            }
                            else
                            {
                                <span class="badge-soft badge-soft-secondary">SECUNDARIA</span>
                            }
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="label">Fecha registro</div>
                        <div class="value">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>

                </div>
            </div>

            <div class="card-footer bg-white d-flex justify-content-between align-items-center">
                <small class="text-muted">ID: @Model.ProductoImagenId</small>
                <a asp-action="Delete" asp-route-id="@Model.ProductoImagenId" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash me-1"></i> Eliminar
                </a>
            </div>
        </div>
    </div>

    <!-- Preview -->
    <div class="col-lg-5 col-xl-6">
        <div class="card shadow-sm cardx">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="fw-semibold">Vista previa</div>
                </div>

                <div class="preview">
                    @if (!string.IsNullOrWhiteSpace(Model.Url))
                    {
                        <img src="@Model.Url" alt="Vista previa" loading="lazy" />
                    }
                    else
                    {
                        <span>PREVIEW</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>