@model TiendaOnline.AppMVC.Models.ProductoImagen

@{
    ViewData["Title"] = "Eliminar imagen";
    var esPrincipal = Model.EsPrincipal;
    var productoNombre = Model.Producto?.Nombre;
    var productoId = Model.ProductoId;
}


<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">Eliminar imagen</h3>
        <div class="text-muted">Esta acción no se puede deshacer</div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        ← Volver
    </a>
</div>

<div class="row g-3">
    <!-- Info -->
    <div class="col-lg-7 col-xl-6">
        <div class="card shadow-sm cardx">
            <div class="card-body p-4">

                <div class="warning-box mb-4">
                    ⚠ ¿Seguro que deseas eliminar esta imagen?
                </div>

                <div class="row g-3">
                    <div class="col-12">
                        <div class="label">Producto</div>
                        <div class="value">
                            @(string.IsNullOrWhiteSpace(productoNombre) ? $"Producto #{productoId}" : productoNombre)
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="label">URL</div>
                        <div class="value mono truncate">@Model.Url</div>
                    </div>

                    <div class="col-md-6">
                        <div class="label">Tipo</div>
                        <div class="value">
                            @if (esPrincipal)
                            {
                                <span class="badge-soft badge-soft-primary">PRINCIPAL</span>
                            }
                            else
                            {
                                <span class="badge-soft badge-soft-secondary">SECUNDARIA</span>
                            }
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="label">Fecha registro</div>
                        <div class="value">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                </div>

                <hr class="my-4" />

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ProductoImagenId" />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i> Confirmar eliminación
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancelar
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <!-- Preview -->
    <div class="col-lg-5 col-xl-6">
        <div class="card shadow-sm cardx">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="fw-semibold">Vista previa</div>
                    <small class="text-muted">Imagen actual</small>
                </div>

                <div class="preview">
                    @if (!string.IsNullOrWhiteSpace(Model.Url))
                    {
                        <img src="@Model.Url" alt="Vista previa" loading="lazy" />
                    }
                    else
                    {
                        <span>PREVIEW</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>