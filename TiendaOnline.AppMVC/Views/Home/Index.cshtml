@model TiendaOnline.AppMVC.Models.ViewModels.DashboardVM

@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
<style>
    .cardx { border-radius: 16px; }
    .kpi-title { font-size: .78rem; letter-spacing: .12em; text-transform: uppercase; color: #94a3b8; font-weight: 800; }
    .kpi-value { font-size: 1.6rem; font-weight: 900; color: #0f172a; }
    .kpi-icon {
        width: 44px; height: 44px; border-radius: 14px;
        display: inline-flex; align-items:center; justify-content:center;
        background: rgba(13,110,253,.12);
        color: #0d6efd;
    }
    .rowx { padding: 14px 16px; }
    .rowx + .rowx { border-top: 1px solid rgba(0,0,0,.05); }
</style>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">Dashboard</h3>
        <div class="text-muted">Resumen rápido del sistema</div>
    </div>
</div>

<!-- KPIs -->
<div class="row g-3">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm cardx">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="kpi-title">Productos</div>
                    <div class="kpi-value">@Model.TotalProductos</div>
                </div>
                <div class="kpi-icon"><i class="bi bi-box-seam"></i></div>
            </div>
            <div class="card-footer bg-white">
                <a class="text-decoration-none" asp-controller="Producto" asp-action="Index">Ver productos →</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm cardx">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="kpi-title">Imágenes</div>
                    <div class="kpi-value">@Model.TotalImagenes</div>
                </div>
                <div class="kpi-icon"><i class="bi bi-image"></i></div>
            </div>
            <div class="card-footer bg-white">
                <a class="text-decoration-none" asp-controller="ProductoImagen" asp-action="Index">Gestionar →</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm cardx">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="kpi-title">Pedidos</div>
                    <div class="kpi-value">@Model.TotalPedidos</div>
                </div>
                <div class="kpi-icon"><i class="bi bi-receipt"></i></div>
            </div>
            <div class="card-footer bg-white">
                <a class="text-decoration-none" asp-controller="Pedidos" asp-action="Index">Ver pedidos →</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm cardx">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="kpi-title">Usuarios</div>
                    <div class="kpi-value">@Model.TotalUsuarios</div>
                </div>
                <div class="kpi-icon"><i class="bi bi-people"></i></div>
            </div>
            <div class="card-footer bg-white">
                <a class="text-decoration-none" asp-controller="Usuarios" asp-action="Index">Ver usuarios →</a>
            </div>
        </div>
    </div>
</div>

<!-- Productos recientes -->
<div class="row g-3 mt-1">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm cardx">
            <div class="card-body p-0">
                <div class="px-3 py-3 d-flex align-items-center justify-content-between">
                    <div>
                        <div class="fw-bold">Productos recientes</div>
                        <div class="text-muted small">Últimos 5 registrados</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Producto" asp-action="Create">
                        <i class="bi bi-plus-lg me-1"></i> Nuevo
                    </a>
                </div>

                @if (Model.ProductosRecientes == null || !Model.ProductosRecientes.Any())
                {
                    <div class="px-3 pb-3 text-muted">No hay productos aún.</div>
                }
                else
                {
                    foreach (var p in Model.ProductosRecientes)
                    {
                        <div class="rowx d-flex align-items-center justify-content-between">
                            <div>
                                <div class="fw-semibold">@p.Nombre</div>
                                <div class="text-muted small">@p.FechaRegistro.ToString("dd/MM/yyyy")</div>
                            </div>
                            <div class="fw-bold">$@p.Precio.ToString("0.00")</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Accesos rápidos -->
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm cardx">
            <div class="card-body">
                <div class="fw-bold mb-2">Accesos rápidos</div>

                <div class="d-grid gap-2">
                    <a class="btn btn-outline-primary" asp-controller="Producto" asp-action="Index">
                        <i class="bi bi-box-seam me-1"></i> Productos
                    </a>
                    <a class="btn btn-outline-primary" asp-controller="ProductoImagen" asp-action="Index">
                        <i class="bi bi-image me-1"></i> Imágenes
                    </a>
                    <a class="btn btn-outline-primary" asp-controller="Pedidos" asp-action="Index">
                        <i class="bi bi-receipt me-1"></i> Pedidos
                    </a>
                    <a class="btn btn-outline-primary" asp-controller="Usuarios" asp-action="Index">
                        <i class="bi bi-people me-1"></i> Usuarios
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>